  <meta name="twitter:image" content="/img/pimbaluimg.jpg" />

  <!-- Structured Data: Local Business -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FoodEstablishment",
    "name": "Pimbalú Delicias Caseras",
    "description": "Dulces artesanales elaborados con ingredientes naturales: chupetines, tabletas de chocolate, cupcakes personalizados, flan y caramelos. Pedidos por Instagram y WhatsApp con envío a domicilio.",
    "image": "/img/pimbaluimg.jpg",
    "url": "https://www.instagram.com/pimbalu/",
    "telephone": "+56987666641",
    "sameAs": ["https://www.instagram.com/pimbalu/"],
    "servesCuisine": "Repostería artesanal",
    "hasMenu": "https://www.instagram.com/pimbalu/",
    "priceRange": "$"
  }
  </script>

  <link rel="icon" type="image/png" href="/img/icon-removebg.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <script is:inline src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body>
  <slot />

  <script is:inline>
    lucide.createIcons();
    document.getElementById('footer-year').textContent = new Date().getFullYear();
