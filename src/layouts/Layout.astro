<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pimbalú Delicias Caseras | Dulces artesanales con envío a domicilio</title>
  <meta name="description" content="Pimbalú elabora dulces artesanales, chupetines, tabletas de chocolate, cupcakes y postres caseros hechos con ingredientes naturales. Pide por Instagram o WhatsApp y recíbelos en casa." />
  <meta name="keywords" content="dulces artesanales, chupetines, chocolate casero, cupcakes personalizados, postres, caramelos, delicias caseras, repostería, envío a domicilio, Pimbalú" />
  <meta name="author" content="Pimbalú Delicias Caseras" />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Pimbalú Delicias Caseras | Dulces artesanales con envío a domicilio" />
  <meta property="og:description" content="Chupetines, chocolates, cupcakes y postres caseros hechos con amor y los mejores ingredientes. Pide por Instagram o WhatsApp." />
